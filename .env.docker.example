# Copy this file to .env.docker and edit before running docker compose.
# The defaults work for local development without any changes.
#
# Usage:
#   docker compose --env-file .env.docker up --build

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate a secure value for production: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production-min-32-chars

# ── Ollama (local LLM — optional) ────────────────────────────────────────────
# Ollama should be running on your host machine.
# host.docker.internal resolves to the host IP from inside Docker on Mac/Windows.
# On Linux use: http://172.17.0.1:11434  (or the actual docker0 bridge IP)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# ── Tavily web search (optional) ─────────────────────────────────────────────
TAVILY_API_KEY=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

# ── Frontend ──────────────────────────────────────────────────────────────────
# The URL the BROWSER uses to reach the backend API.
# For local Docker, localhost:8000 works because the backend container
# publishes port 8000 to the host.
VITE_API_URL=http://localhost:8000
