# ── HOW TO USE ────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp 02-secrets.yaml.example 02-secrets.yaml
# 2. Base64-encode your values:
#      echo -n "your-value-here" | base64
# 3. Replace the placeholder strings below with your encoded values.
# 4. Apply: kubectl apply -f 02-secrets.yaml
#
# IMPORTANT: 02-secrets.yaml is listed in .gitignore — never commit real secrets.
# ──────────────────────────────────────────────────────────────────────────────

apiVersion: v1
kind: Secret
metadata:
  name: forkfinder-secrets
  namespace: forkfinder
type: Opaque
data:
  # Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
  # Then base64-encode the result.
  # echo -n "dev-secret-change-in-production-min-32-chars" | base64
  SECRET_KEY: ZGV2LXNlY3JldC1jaGFuZ2UtaW4tcHJvZHVjdGlvbi1taW4tMzItY2hhcnM=

  # Optional — Tavily API key. Leave empty string if not used.
  # echo -n "" | base64  →  (empty)
  TAVILY_API_KEY: ""
